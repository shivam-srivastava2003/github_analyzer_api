    {
      "name": "Analyze Profile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"torvalds\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/profiles/analyze",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles",
            "analyze"
          ]
        },
        "description": "Analyze a user profile. If found in local DB, acts as cache hit. If not found, fetches from GitHub, processes, saves to DB, and returns."
      },
      "response": []
    },
    {
      "name": "Get All Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles?page=1&limit=10&sort=engagement_score&order=DESC&search=",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles"
          ],
          "query": [
            {
              "key": "page",
              "value": "1",
              "description": "Page number (defaults to 1)"
            },
            {
              "key": "limit",
              "value": "10",
              "description": "Profiles count per page (defaults to 10)"
            },
            {
              "key": "sort",
              "value": "engagement_score",
              "description": "Field to sort by (followers, engagement_score, etc.)"
            },
            {
              "key": "order",
              "value": "DESC",
              "description": "ASC or DESC"
            },
            {
              "key": "search",
              "value": "",
              "description": "Search keyword matching username or name"
            }
          ]
        },
        "description": "Retrieve paginated, sorted, and searched database profiles."
      },
      "response": []
