# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=railway

# GitHub API Configuration
# Optional: Personal Access Token to bypass public API limits (60 req/hour)
GITHUB_TOKEN=

# Security & Rate Limiting
# Window in milliseconds (e.g., 15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window per IP
RATE_LIMIT_MAX=100
