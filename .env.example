# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=github_analyzer_db

# GitHub API Configuration
# Recommended to set a token to bypass GitHub API's 60 req/hour limit for unauthenticated requests
GITHUB_TOKEN=

# Security & Rate Limiting
# Window in milliseconds (e.g., 15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window per IP
RATE_LIMIT_MAX=100
